{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true
  },
  "include": ["main.ts", "components/**/*.ts", "config/**/*.ts", "data/**/*.ts", "types/**/*.ts"],
  "exclude": ["electron", "dist", "dist-electron", "node_modules", "scripts"]
}
